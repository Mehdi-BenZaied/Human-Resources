# ── Database ──────────────────────────────────────────────────────────────────
DB_ROOT_PASSWORD=root
DB_NAME=hr_portal
DB_USER=hr_user
DB_PASSWORD=hr_password

# ── Backend ───────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
APP_ENV=production
BCRYPT_ROUNDS=12

# ── CORS ──────────────────────────────────────────────────────────────────────
# In production set this to your actual frontend domain
CORS_ORIGINS=http://localhost:4200

# ── Frontend build arg ────────────────────────────────────────────────────────
# The URL the browser uses to reach the API.
# In Docker on the same host both containers share hr_net so use the service name.
# If behind a reverse proxy, set to your public API domain: https://api.example.com
API_BASE_URL=http://backend:4000
