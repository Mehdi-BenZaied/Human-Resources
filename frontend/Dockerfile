# ─────────────────────────────────────────────────────────────────────────────
# Stage 1 — deps
#   Installs ALL dependencies (dev + prod) needed to compile Angular.
#   Kept in its own stage so the build layer is cached independently.
# ─────────────────────────────────────────────────────────────────────────────
FROM node:22-alpine AS deps

WORKDIR /app

# Copy manifests only — changes here invalidate the install layer
COPY package.json package-lock.json ./

# Clean, reproducible install from the lockfile
RUN npm ci --prefer-offline


# ─────────────────────────────────────────────────────────────────────────────
# Stage 2 — builder
#   Compiles the Angular app with `ng build --configuration production`.
#   The API base URL is baked into the bundle at build time.
#
#   Build arg:
#     API_BASE_URL  URL the end-user's browser will use to reach the API.
#                   Default: http://localhost:4000  (host-forwarded port)
#                   Production: https://api.yourdomain.com
# ─────────────────────────────────────────────────────────────────────────────
FROM node:22-alpine AS builder

WORKDIR /app

# Reuse the full node_modules from the deps stage
COPY --from=deps /app/node_modules ./node_modules

# Copy source
COPY . .

ARG API_BASE_URL=http://localhost:4000

# Patch the production environment file before compiling
RUN sed -i "s|http://localhost:4000|${API_BASE_URL}|g" \
        src/environments/environment.prod.ts

# Production build — emits dist/DevopsMastering/{browser,server}
RUN npx ng build --configuration production

# ─────────────────────────────────────────────────────────────────────────────
# Stage 3 — prod-deps
#   Installs ONLY production dependencies using --omit=dev.
#   This stage exists purely to produce a lean node_modules for the runtime.
#   (~300 MB all deps → ~80 MB prod-only deps)
# ─────────────────────────────────────────────────────────────────────────────
FROM node:22-alpine AS prod-deps

WORKDIR /app

COPY package.json package-lock.json ./

RUN npm ci --omit=dev --prefer-offline


# ─────────────────────────────────────────────────────────────────────────────
# Stage 4 — runtime
#   Minimal Node 22 Alpine image.
#   Contains only:
#     • The compiled SSR output  (dist/)
#     • Production node_modules  (~80 MB, no devDependencies)
#   No source code, no Angular CLI, no TypeScript compiler.
# ─────────────────────────────────────────────────────────────────────────────
FROM node:22-alpine AS runtime

ENV NODE_ENV=production \
    PORT=4200

# Non-root user
RUN addgroup -S appgroup \
 && adduser  -S appuser -G appgroup

WORKDIR /app

# ① Compiled Angular SSR bundles
COPY --from=builder   --chown=appuser:appgroup /app/dist/DevopsMastering ./dist/DevopsMastering

# ② Production-only node_modules (express, @angular/platform-server, etc.)
COPY --from=prod-deps --chown=appuser:appgroup /app/node_modules          ./node_modules

USER appuser

EXPOSE 4200

# Healthcheck — wget is available in alpine by default
HEALTHCHECK --interval=15s --timeout=5s --start-period=20s --retries=3 \
    CMD wget -qO- http://localhost:4200 || exit 1

# Angular SSR server generated by ng build
CMD ["node", "dist/DevopsMastering/server/server.mjs"]
